# ===== GOOGLE API =====
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_CALENDAR_ID=your-calendar@gmail.com

# For deployed environments (Render/Railway): non-interactive OAuth
# Recommended app type in Google Cloud Console: Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
ALLOW_INTERACTIVE_OAUTH=True

# ===== GOOGLE GEMINI API =====
GEMINI_API_KEY=your-gemini-api-key

# ===== EMAIL CONFIGURATION =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Aevum AI

# ===== LINKEDIN CONFIGURATION =====
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/integrations/linkedin/oauth/callback
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# ===== APP CONFIGURATION =====
APP_NAME=Aevum AI - Event Publicity Agent
APP_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=DEBUG

# ===== MODE =====
# Keep False for full-system production mode.
ALLOW_DEMO_MODE=False

DATABASE_URL=sqlite:///./aevum_ai.db
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

SCHEDULER_ENABLED=True
SCHEDULER_INTERVAL_HOURS=6

TEAM_EMAIL=team@university.edu
NEXT_PUBLIC_DEFAULT_ACCOUNT_EMAIL=vajinapalli.abhinav@gmail.com
